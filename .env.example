# База данных (Railway)
DATABASE_URL=postgresql://user:password@host:port/database

# Telegram бот
TELEGRAM_BOT_TOKEN=your_bot_token
# Куда слать заказы менеджеру: числовой Telegram ID (напр. 7794513958 для @CEO_PE). Обязательно — иначе "chat not found"
# TELEGRAM_ORDER_CHAT_ID=7794513958
# Имя бота для ссылки «Перейти в Telegram» (опционально, иначе берётся из getMe)
# TELEGRAM_BOT_USERNAME=YourBotName

# URL мини-апп (для кнопки в боте)
APP_URL=https://your-mini-app-url.com

# Секрет админки (по умолчанию admin123)
ADMIN_SECRET=your_admin_secret

# Секрет для сессий (обязательно задайте в продакшене)
# SESSION_SECRET=random_long_secret_string
